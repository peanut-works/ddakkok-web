# 백엔드 API 베이스 URL (끝에 / 없이)
VITE_API_URL=http://localhost:8000

# 출시 알림(이메일 수집) — Web3Forms access key
# https://web3forms.com 에서 받을 이메일 주소만 입력하면 무료로 발급됩니다.
# 비워두면 데모 모드로 동작(이메일을 브라우저에만 저장하고 화면은 정상 작동).
VITE_WAITLIST_KEY=
# (선택) 다른 폼 서비스를 쓸 때만 변경. 기본값은 Web3Forms.
# VITE_WAITLIST_URL=https://api.web3forms.com/submit
